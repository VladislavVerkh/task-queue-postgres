        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "select\n  schemaname || '.' || relname as table_name,\n  n_live_tup,\n  n_dead_tup,\n  round(100.0 * n_dead_tup / greatest(n_live_tup + n_dead_tup, 1), 2) as dead_pct,\n  last_vacuum,\n  last_autovacuum,\n  vacuum_count,\n  autovacuum_count\nfrom pg_stat_user_tables\norder by n_dead_tup desc\nlimit 20;",
          "refId": "A"
        }
      ],
      "title": "Vacuum Health by Table",
      "type": "table"
