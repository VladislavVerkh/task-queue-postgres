      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "select\n  queryid::text as query_id,\n  calls,\n  round(total_exec_time::numeric, 2) as total_exec_ms,\n  round(mean_exec_time::numeric, 2) as mean_exec_ms,\n  round(max_exec_time::numeric, 2) as max_exec_ms,\n  rows,\n  left(regexp_replace(query, '\\\\s+', ' ', 'g'), 220) as query\nfrom pg_stat_statements\nwhere dbid = (select oid from pg_database where datname = current_database())\norder by total_exec_time desc\nlimit 20;",
          "refId": "A"
        }
      ],
      "title": "Top SQL by Total Exec Time (pg_stat_statements)",
      "type": "table"
    },
